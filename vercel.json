{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/style.css", "dest": "/index.js" },
    { "src": "/app.js", "dest": "/index.js" },
    { "src": "/assets/(.*)", "dest": "/index.js" },
    { "src": "/notifications.json", "dest": "/index.js" },
    { "src": "/(.*)", "dest": "/index.js" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
